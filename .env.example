# Copia questo file in .env e compila i valori

# Memgraph (lascia i default se usi docker-compose)
MEMGRAPH_HOST=memgraph
MEMGRAPH_PORT=7687

# Ollama (lascia il default se usi Ollama in locale su Windows/Mac con Docker)
OLLAMA_HOST=http://host.docker.internal:11434

# Modelli Ollama (cambia con quelli che hai installato)
EMBED_MODEL=nomic-embed-text       # modello per gli embedding (deve produrre vettori da 768 dimensioni)
PLANNER_MODEL=llama3.2:3b          # modello leggero per classificare la domanda (3-7B consigliato)
SYNTHESIZER_MODEL=llama3           # modello principale per generare le risposte (7B+ consigliato)
